# Kimi API Key (必需)
# 从 https://platform.moonshot.cn/ 获取
MOONSHOT_API_KEY=your_kimi_api_key_here

# Gemini API Key (必需)
# 从 https://aistudio.google.com/app/apikey 获取
GEMINI_API_KEY=your_gemini_api_key_here

# 可选：闲鱼登录信息（如需要自动发布）
# 注意：自动登录可能触发风控，建议手动扫码
XIANYU_USERNAME=your_phone_or_email
XIANYU_PASSWORD=your_password

# IDM-VTON Service Configuration
# IDM-VTON服务地址（虚拟试衣）
IDM_VTON_SERVICE_URL=http://localhost:8001
# IDM-VTON模型路径
IDM_VTON_ROOT=/home/zhaoliyang/IDM-VTON
IDM_VTON_CHECKPOINT=/home/zhaoliyang/IDM-VTON/checkpoints
